<?xml version="1.0" encoding="utf-8" standalone="no" ?>
<GUI name="WCDashboard">
    <GuiElement profile="uiInGameMenuFrame">

        <!-- Tab header -->
        <GuiElement profile="fs25_menuHeaderPanel">
            <Bitmap profile="fs25_menuHeaderIconBg"/>
            <Text profile="fs25_menuHeaderTitle" text="$l10n_wc_tab_dashboard"/>
        </GuiElement>

        <GuiElement profile="fs25_subCategorySelectorTabbedContainer" position="0px -80px">

            <!-- LEFT: Status + Payment info -->
            <ThreePartBitmap profile="fs25_primaryMenuContainerBg" width="540px" height="620px" position="0px 20px">
                <Bitmap profile="fs25_menuContainerArrow"/>
                <GuiElement profile="fs25_subCategoryContainer" width="500px">

                    <!-- MOD STATUS -->
                    <Text profile="WC_SectionTitle" position="10px -10px" text="$l10n_wc_section_status"/>
                    <ThreePartBitmap profile="fs25_lineSeparatorTop" position="5px -34px" width="480px"/>

                    <BoxLayout profile="WC_ColBoxV" position="5px -50px" width="480px">
                        <BoxLayout profile="WC_RowBoxH" width="480px">
                            <Text profile="WC_RowLabel" text="$l10n_wc_label_mod_enabled" width="220px"/>
                            <Text profile="WC_RowValue" id="txtModEnabled" width="250px"/>
                        </BoxLayout>
                        <BoxLayout profile="WC_RowBoxH" width="480px">
                            <Text profile="WC_RowLabel" text="$l10n_wc_label_cost_mode" width="220px"/>
                            <Text profile="WC_RowValue" id="txtCostMode" width="250px"/>
                        </BoxLayout>
                        <BoxLayout profile="WC_RowBoxH" width="480px">
                            <Text profile="WC_RowLabel" text="$l10n_wc_label_current_rate" width="220px"/>
                            <Text profile="WC_RowValueGreen" id="txtCurrentRate" width="250px"/>
                        </BoxLayout>
                    </BoxLayout>

                    <!-- PAYMENT INFO -->
                    <Text profile="WC_SectionTitle" position="10px -178px" text="$l10n_wc_section_payment"/>
                    <ThreePartBitmap profile="fs25_lineSeparatorTop" position="5px -202px" width="480px"/>

                    <!-- Big countdown timer -->
                    <Text profile="WC_BigStatLabel" position="10px -224px" text="$l10n_wc_label_next_payment"/>
                    <Text profile="WC_BigStat" id="txtNextPayment" position="10px -244px"/>

                    <ThreePartBitmap profile="fs25_lineSeparatorTop" position="5px -298px" width="480px"/>

                    <BoxLayout profile="WC_ColBoxV" position="5px -314px" width="480px">
                        <BoxLayout profile="WC_RowBoxH" width="480px">
                            <Text profile="WC_RowLabel" text="$l10n_wc_label_est_cost" width="220px"/>
                            <Text profile="WC_RowValueGreen" id="txtEstimatedCost" width="250px"/>
                        </BoxLayout>
                        <BoxLayout profile="WC_RowBoxH" width="480px">
                            <Text profile="WC_RowLabel" text="$l10n_wc_label_farm_balance" width="220px"/>
                            <Text profile="WC_RowValue" id="txtFarmBalance" width="250px"/>
                        </BoxLayout>
                    </BoxLayout>

                </GuiElement>
            </ThreePartBitmap>

            <!-- Vertical separator -->
            <Bitmap profile="fs25_settingsTooltipSeparator" position="560px 0px"/>

            <!-- RIGHT: Active workers -->
            <GuiElement position="580px 30px" width="460px" height="620px">

                <!-- Big worker count -->
                <Text profile="WC_SectionTitle" position="0px -10px" text="$l10n_wc_section_workers"/>
                <ThreePartBitmap profile="fs25_lineSeparatorTop" position="0px -34px" width="440px"/>

                <Text profile="WC_BigStat" id="txtWorkerCount" position="0px -56px"/>
                <Text profile="WC_BigStatLabel" position="0px -104px" text="$l10n_wc_label_active_workers"/>

                <!-- Worker names list -->
                <Text profile="WC_SectionTitle" position="0px -136px" text="$l10n_wc_label_worker_list"/>
                <ThreePartBitmap profile="fs25_lineSeparatorTop" position="0px -160px" width="440px"/>
                <Text profile="WC_BodyText" id="txtWorkerNames" position="0px -180px" width="440px"/>

            </GuiElement>

        </GuiElement>

    </GuiElement>
</GUI>
