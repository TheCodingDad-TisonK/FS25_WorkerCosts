<?xml version="1.0" encoding="utf-8" standalone="no" ?>
<GUI name="WCDashboard">
    <GuiElement profile="uiInGameMenuFrame">

        <!-- Tab header -->
        <GuiElement profile="fs25_menuHeaderPanel">
            <Bitmap profile="fs25_menuHeaderIconBg">
                <Bitmap profile="fs25_menuHeaderIcon" filename="$modDir/tab_icons.dds" uvs="0 0 0.5 0 0.5 0.5 0 0.5"/>
            </Bitmap>
            <Text profile="fs25_menuHeaderTitle" text="$l10n_wc_tab_dashboard"/>
        </GuiElement>

        <GuiElement profile="fs25_subCategorySelectorTabbedContainer" position="0px -80px">

            <!-- LEFT: Status + Finances sidebar (narrow ~30%) -->
            <ThreePartBitmap profile="fs25_primaryMenuContainerBg" width="340px" height="480px" position="0px 20px">
                <Bitmap profile="fs25_menuContainerArrow"/>
                <GuiElement profile="fs25_subCategoryContainer" width="300px">

                    <Text profile="WC_SectionTitle" position="10px -10px" text="$l10n_wc_section_status"/>
                    <ThreePartBitmap profile="fs25_lineSeparatorTop" position="5px -34px" width="280px"/>

                    <!-- Rows individually positioned — no ColBoxV wrapper -->
                    <BoxLayout profile="WC_RowBoxH" position="5px -52px" width="290px">
                        <Text profile="WC_RowLabel" text="$l10n_wc_label_mod_enabled" width="130px"/>
                        <Text profile="WC_RowValue" id="txtModEnabled" width="150px"/>
                    </BoxLayout>
                    <BoxLayout profile="WC_RowBoxH" position="5px -80px" width="290px">
                        <Text profile="WC_RowLabel" text="$l10n_wc_label_cost_mode" width="130px"/>
                        <Text profile="WC_RowValue" id="txtCostMode" width="150px"/>
                    </BoxLayout>
                    <BoxLayout profile="WC_RowBoxH" position="5px -108px" width="290px">
                        <Text profile="WC_RowLabel" text="$l10n_wc_label_wage_level" width="130px"/>
                        <Text profile="WC_RowValue" id="txtWageLevel" width="150px"/>
                    </BoxLayout>
                    <BoxLayout profile="WC_RowBoxH" position="5px -136px" width="290px">
                        <Text profile="WC_RowLabel" text="$l10n_wc_label_current_rate" width="130px"/>
                        <Text profile="WC_RowValueGreen" id="txtCurrentRate" width="150px"/>
                    </BoxLayout>

                    <Text profile="WC_SectionTitle" position="10px -172px" text="$l10n_wc_section_payment"/>
                    <ThreePartBitmap profile="fs25_lineSeparatorTop" position="5px -196px" width="280px"/>

                    <BoxLayout profile="WC_RowBoxH" position="5px -214px" width="290px">
                        <Text profile="WC_RowLabel" text="$l10n_wc_label_est_cost" width="130px"/>
                        <Text profile="WC_RowValueGreen" id="txtEstimatedCost" width="150px"/>
                    </BoxLayout>
                    <BoxLayout profile="WC_RowBoxH" position="5px -242px" width="290px">
                        <Text profile="WC_RowLabel" text="$l10n_wc_label_farm_balance" width="130px"/>
                        <Text profile="WC_RowValue" id="txtFarmBalance" width="150px"/>
                    </BoxLayout>

                </GuiElement>
            </ThreePartBitmap>

            <!-- Vertical separator -->
            <Bitmap profile="fs25_settingsTooltipSeparator" position="356px 0px"/>

            <!-- RIGHT: Live data (~70%) -->
            <GuiElement position="374px 30px" width="660px" height="480px">

                <!-- Countdown as hero element -->
                <Text profile="WC_BigStatLabel" position="0px -10px" text="$l10n_wc_label_next_payment"/>
                <Text profile="WC_BigStat" id="txtNextPayment" position="0px -30px"/>

                <ThreePartBitmap profile="fs25_lineSeparatorTop" position="0px -84px" width="640px"/>

                <Text profile="WC_SectionTitle" position="0px -106px" text="$l10n_wc_section_workers"/>
                <ThreePartBitmap profile="fs25_lineSeparatorTop" position="0px -130px" width="640px"/>

                <Text profile="WC_BigStat" id="txtWorkerCount" position="0px -152px"/>
                <Text profile="WC_BigStatLabel" position="0px -202px" text="$l10n_wc_label_active_workers"/>

                <ThreePartBitmap profile="fs25_lineSeparatorTop" position="0px -226px" width="640px"/>

                <Text profile="WC_SectionTitle" position="0px -248px" text="$l10n_wc_label_worker_list"/>
                <ThreePartBitmap profile="fs25_lineSeparatorTop" position="0px -272px" width="640px"/>

                <Text profile="WC_BodyText" id="txtWorkerNames" position="0px -292px" size="640px 180px"/>

            </GuiElement>

        </GuiElement>

    </GuiElement>
</GUI>
