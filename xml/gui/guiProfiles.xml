<?xml version="1.0" encoding="utf-8" standalone="no" ?>
<GUIProfiles>
    <!-- ============================================================ -->
    <!-- Worker Costs Mod: GUI profiles                               -->
    <!-- All WC_ prefixed to avoid collision with other mods          -->
    <!-- ============================================================ -->

    <!-- Layout helpers -->
    <Profile name="WC_RowBoxH" extends="emptyPanel" with="anchorTopLeft">
        <layoutDirection value="horizontal"/>
        <layoutSpacing value="10px"/>
        <clipChildren value="false"/>
    </Profile>

    <Profile name="WC_ColBoxV" extends="emptyPanel" with="anchorTopLeft">
        <layoutDirection value="vertical"/>
        <layoutSpacing value="6px"/>
        <clipChildren value="false"/>
    </Profile>

    <!-- Section header: small, bold, uppercase -->
    <Profile name="WC_SectionTitle" extends="fs25_textDefault" with="anchorTopLeft">
        <textSize value="16px"/>
        <textBold value="true"/>
        <textUpperCase value="true"/>
        <textColor value="1 1 1 1"/>
        <textAlignment value="left"/>
    </Profile>

    <!-- Row label: left-aligned, slightly dimmed -->
    <Profile name="WC_RowLabel" extends="fs25_textDefault" with="anchorTopLeft">
        <textSize value="18px"/>
        <textBold value="false"/>
        <textColor value="1 1 1 0.8"/>
        <textAlignment value="left"/>
        <width value="200px"/>
    </Profile>

    <!-- Row value: right-aligned, bold, bright -->
    <Profile name="WC_RowValue" extends="fs25_textDefault" with="anchorTopRight">
        <textSize value="18px"/>
        <textBold value="true"/>
        <textColor value="1 1 1 1"/>
        <textAlignment value="right"/>
        <width value="220px"/>
    </Profile>

    <!-- Highlighted value: green accent (money / active) -->
    <Profile name="WC_RowValueGreen" extends="fs25_textDefault" with="anchorTopRight">
        <textSize value="18px"/>
        <textBold value="true"/>
        <textColor value="0.2 0.8 0.2 1"/>
        <textAlignment value="right"/>
        <width value="220px"/>
    </Profile>

    <!-- Large stat number: big centre display -->
    <Profile name="WC_BigStat" extends="fs25_textDefault" with="anchorTopLeft">
        <textSize value="36px"/>
        <textBold value="true"/>
        <textColor value="0.2 0.8 0.2 1"/>
        <textAlignment value="left"/>
    </Profile>

    <!-- Big stat label underneath -->
    <Profile name="WC_BigStatLabel" extends="fs25_textDefault" with="anchorTopLeft">
        <textSize value="14px"/>
        <textBold value="false"/>
        <textUpperCase value="true"/>
        <textColor value="1 1 1 0.6"/>
    </Profile>

    <!-- Body / list text with wrapping -->
    <Profile name="WC_BodyText" extends="fs25_textDefault" with="anchorTopLeft">
        <textSize value="16px"/>
        <textBold value="false"/>
        <textColor value="1 1 1 0.85"/>
        <textAlignment value="left"/>
        <textWrap value="true"/>
        <width value="380px"/>
    </Profile>

    <!-- Footer wage label -->
    <Profile name="WC_FooterLabel" extends="fs25_textDefault" with="anchorTopLeft">
        <textSize value="18px"/>
        <textBold value="true"/>
        <textColor value="1 1 1 0.6"/>
    </Profile>

    <!-- Footer wage value (green, right) -->
    <Profile name="WC_FooterValue" extends="fs25_textDefault" with="anchorTopRight">
        <textSize value="22px"/>
        <textBold value="true"/>
        <textAlignment value="right"/>
        <textColor value="0.2 0.8 0.2 1"/>
    </Profile>

    <!-- Filter switcher (Hourly / Per Hectare toggle) -->
    <Profile name="WC_FilterSwitcher" extends="fs25_subCategorySelector" with="anchorTopLeft"/>

    <!-- Compact on/off toggle for settings checkboxes (fs25_optionCheckbox does not exist in FS25 1.17) -->
    <Profile name="WC_CheckSwitcher" extends="fs25_subCategorySelector" with="anchorTopLeft"/>

    <!-- Fixed-width coordinate shell for the balance box — right-anchored so it adapts to any header width -->
    <Profile name="WC_MoneyBoxFixedWidth" extends="emptyPanel" with="anchorTopRight"/>

    <!-- Empty state text -->
    <Profile name="WC_EmptyText" extends="fs25_textGrey" with="anchorMiddleCenter">
        <textAlignment value="center"/>
        <textVerticalAlignment value="middle"/>
        <textSize value="22px"/>
    </Profile>

    <!-- Status pill: green when active -->
    <Profile name="WC_StatusActive" extends="fs25_textDefault" with="anchorTopLeft">
        <textSize value="18px"/>
        <textBold value="true"/>
        <textColor value="0.2 0.8 0.2 1"/>
        <textAlignment value="left"/>
    </Profile>

    <Profile name="WC_StatusInactive" extends="fs25_textDefault" with="anchorTopLeft">
        <textSize value="18px"/>
        <textBold value="true"/>
        <textColor value="1 0.35 0.35 1"/>
        <textAlignment value="left"/>
    </Profile>

    <!-- Penalty warning text: red, centred, left-anchored so it stays inside dialog -->
    <Profile name="WC_PenaltyText" extends="fs25_textDefault" with="anchorTopLeft">
        <textSize value="13px"/>
        <textBold value="true"/>
        <textUpperCase value="true"/>
        <textColor value="1 0.4 0.4 1"/>
        <textAlignment value="center"/>
    </Profile>

    <!-- Total row label: left side, left-anchored -->
    <Profile name="WC_TotalLabel" extends="fs25_textDefault" with="anchorTopLeft">
        <textSize value="18px"/>
        <textBold value="true"/>
        <textColor value="1 1 1 0.8"/>
        <textAlignment value="left"/>
    </Profile>

    <!-- Total row value: right side, right-aligned text, left-anchored element -->
    <Profile name="WC_TotalValue" extends="fs25_textDefault" with="anchorTopLeft">
        <textSize value="18px"/>
        <textBold value="true"/>
        <textColor value="0.2 0.8 0.2 1"/>
        <textAlignment value="right"/>
    </Profile>

    <!-- 3-layer interactive buttons (NPCFavor RVB pattern) -->
    <Profile name="WC_BtnBgGreen" extends="baseReference" with="anchorTopLeft">
        <imageColor value="0.12 0.35 0.12 0.95"/>
    </Profile>

    <Profile name="WC_BtnBgRed" extends="baseReference" with="anchorTopLeft">
        <imageColor value="0.35 0.12 0.12 0.95"/>
    </Profile>

    <Profile name="WC_BtnHit" extends="emptyPanel" with="anchorTopLeft">
        <isFocusable value="true"/>
    </Profile>

    <Profile name="WC_BtnText" extends="fs25_textDefault" with="anchorTopLeft">
        <textSize value="18px"/>
        <textBold value="true"/>
        <textColor value="1 1 1 1"/>
        <textAlignment value="center"/>
        <textVerticalAlignment value="middle"/>
    </Profile>
    <!-- Tab button: like the base game tab button but without the hardcoded tractor slice background.
         The icon image is driven entirely by addPageTab() (tab_icons.dds UV per tab). -->
    <Profile name="WC_tabListItemButton" extends="fs25_tabListItemButton">
        <filename value="$dataS/menu/blank.png"/>
        <imageColor value="0 0 0 0"/>
    </Profile>

</GUIProfiles>
