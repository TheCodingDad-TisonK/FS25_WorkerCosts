<?xml version="1.0" encoding="utf-8" standalone="no" ?>
<GUI name="WCMenuPage">
    <GuiElement profile="uiInGameMenuFrame">

        <!-- Header with farm balance display -->
        <GuiElement profile="fs25_menuHeaderPanel">
            <Bitmap profile="fs25_menuHeaderIconBg"/>
            <Text profile="fs25_menuHeaderTitle" text="$l10n_wc_menu_title"/>
            <!-- Fixed 1034px shell keeps the balance box in the right third at any aspect ratio -->
            <GuiElement profile="WC_MoneyBoxFixedWidth" size="1034px 80px">
                <RoundCorner profile="fs25_shopMoneyBoxBg" position="680px 0px"/>
                <BoxLayout profile="fs25_shopMoneyBox" position="648px 0px">
                    <Text profile="fs25_shopBalance" text="$l10n_wc_balance_label"/>
                    <Text profile="fs25_shopMoney" id="txtFarmBalance"/>
                </BoxLayout>
            </GuiElement>
        </GuiElement>

        <GuiElement profile="fs25_subCategorySelectorTabbedContainer" position="0px -80px">

            <!-- LEFT: Status badge + config summary + payment countdown -->
            <ThreePartBitmap profile="fs25_primaryMenuContainerBg" width="340px" height="480px" position="0px 20px">
                <Bitmap profile="fs25_menuContainerArrow"/>
                <GuiElement profile="fs25_subCategoryContainer" width="300px">

                    <Text profile="WC_SectionTitle" position="10px -10px" text="$l10n_wc_section_status"/>
                    <ThreePartBitmap profile="fs25_lineSeparatorTop" position="5px -34px" width="280px"/>

                    <!-- Big active/inactive badge -->
                    <Text profile="WC_BigStat" id="txtModEnabled" position="10px -52px"/>
                    <Text profile="WC_BigStatLabel" position="10px -98px" text="$l10n_wc_label_mod_enabled"/>

                    <ThreePartBitmap profile="fs25_lineSeparatorTop" position="5px -124px" width="280px"/>
                    <Text profile="WC_SectionTitle" position="10px -142px" text="$l10n_wc_section_configuration"/>
                    <ThreePartBitmap profile="fs25_lineSeparatorTop" position="5px -166px" width="280px"/>

                    <BoxLayout profile="WC_RowBoxH" position="5px -184px" width="290px">
                        <Text profile="WC_RowLabel" text="$l10n_wc_label_cost_mode" width="130px"/>
                        <Text profile="WC_RowValue" id="txtCostMode" width="150px"/>
                    </BoxLayout>
                    <BoxLayout profile="WC_RowBoxH" position="5px -212px" width="290px">
                        <Text profile="WC_RowLabel" text="$l10n_wc_label_wage_level" width="130px"/>
                        <Text profile="WC_RowValue" id="txtWageLevel" width="150px"/>
                    </BoxLayout>
                    <BoxLayout profile="WC_RowBoxH" position="5px -240px" width="290px">
                        <Text profile="WC_RowLabel" text="$l10n_wc_label_current_rate" width="130px"/>
                        <Text profile="WC_RowValueGreen" id="txtWageRate" width="150px"/>
                    </BoxLayout>

                    <ThreePartBitmap profile="fs25_lineSeparatorTop" position="5px -274px" width="280px"/>
                    <Text profile="WC_SectionTitle" position="10px -292px" text="$l10n_wc_section_payment"/>
                    <ThreePartBitmap profile="fs25_lineSeparatorTop" position="5px -316px" width="280px"/>

                    <Text profile="WC_BigStatLabel" position="10px -334px" text="$l10n_wc_label_next_payment"/>
                    <Text profile="WC_BigStat" id="txtNextPayment" position="10px -352px"/>

                </GuiElement>
            </ThreePartBitmap>

            <!-- Vertical separator -->
            <Bitmap profile="fs25_settingsTooltipSeparator" position="356px 0px"/>

            <!-- RIGHT: Prominent open button + quick overview -->
            <GuiElement position="374px 30px" width="660px" height="480px">

                <!-- Prominent Open Manager button (hero CTA) -->
                <Bitmap profile="WC_BtnBgGreen" id="btnOpenManagerBg" position="90px -14px" size="480px 56px"/>
                <Button profile="WC_BtnHit" position="90px -14px" size="480px 56px"
                        onClick="onOpenManager" onFocus="onBtnOpenManagerFocus" onLeave="onBtnOpenManagerLeave"/>
                <Text profile="WC_BtnText" position="90px -14px" size="480px 56px" text="$l10n_wc_btn_open_manager"/>

                <ThreePartBitmap profile="fs25_lineSeparatorTop" position="0px -88px" width="640px"/>

                <!-- Workers quick stat -->
                <Text profile="WC_SectionTitle" position="0px -108px" text="$l10n_wc_section_workers"/>
                <ThreePartBitmap profile="fs25_lineSeparatorTop" position="0px -132px" width="640px"/>

                <Text profile="WC_BigStat" id="txtActiveWorkers" position="0px -154px"/>
                <Text profile="WC_BigStatLabel" position="0px -202px" text="$l10n_wc_label_active_workers"/>

                <ThreePartBitmap profile="fs25_lineSeparatorTop" position="0px -228px" width="640px"/>

                <!-- Cost summary row -->
                <BoxLayout profile="WC_RowBoxH" position="0px -250px" width="640px">
                    <Text profile="WC_RowLabel" text="$l10n_wc_label_est_cost" width="300px"/>
                    <Text profile="WC_RowValueGreen" id="txtEstCost" width="330px"/>
                </BoxLayout>

                <ThreePartBitmap profile="fs25_lineSeparatorTop" position="0px -286px" width="640px"/>

                <!-- Description / tagline -->
                <Text profile="WC_BodyText" position="0px -306px" size="640px 150px" text="$l10n_wc_menu_description"/>

            </GuiElement>

        </GuiElement>

    </GuiElement>
</GUI>
