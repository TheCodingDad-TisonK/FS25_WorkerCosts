<?xml version="1.0" encoding="utf-8" standalone="no" ?>
<GUI name="WCWageSettings">
    <GuiElement profile="uiInGameMenuFrame">

        <!-- Tab header -->
        <GuiElement profile="fs25_menuHeaderPanel">
            <Bitmap profile="fs25_menuHeaderIconBg"/>
            <Text profile="fs25_menuHeaderTitle" text="$l10n_wc_tab_wage_settings"/>
        </GuiElement>

        <GuiElement profile="fs25_subCategorySelectorTabbedContainer" position="0px -80px">

            <!-- LEFT: Settings controls -->
            <ThreePartBitmap profile="fs25_primaryMenuContainerBg" width="600px" height="580px" position="0px 20px">
                <Bitmap profile="fs25_menuContainerArrow"/>
                <GuiElement profile="fs25_subCategoryContainer" width="560px">

                    <!-- GENERAL -->
                    <Text profile="WC_SectionTitle" position="10px -10px" text="$l10n_wc_section_general"/>
                    <ThreePartBitmap profile="fs25_lineSeparatorTop" position="5px -34px" width="540px"/>

                    <BoxLayout profile="WC_RowBoxH" position="5px -52px" width="540px">
                        <CheckedOption profile="fs25_optionCheckbox" id="optEnabled"/>
                        <Text profile="WC_RowLabel" text="$l10n_wc_enabled_short" width="420px"/>
                    </BoxLayout>

                    <BoxLayout profile="WC_RowBoxH" position="5px -90px" width="540px">
                        <CheckedOption profile="fs25_optionCheckbox" id="optNotifications"/>
                        <Text profile="WC_RowLabel" text="$l10n_wc_notifications_short" width="420px"/>
                    </BoxLayout>

                    <BoxLayout profile="WC_RowBoxH" position="5px -128px" width="540px">
                        <CheckedOption profile="fs25_optionCheckbox" id="optDebugMode"/>
                        <Text profile="WC_RowLabel" text="$l10n_wc_debug_short" width="420px"/>
                    </BoxLayout>

                    <!-- COST MODE -->
                    <Text profile="WC_SectionTitle" position="10px -182px" text="$l10n_wc_section_cost_mode"/>
                    <ThreePartBitmap profile="fs25_lineSeparatorTop" position="5px -206px" width="540px"/>

                    <BoxLayout profile="WC_RowBoxH" position="5px -226px" width="540px">
                        <Text profile="WC_RowLabel" text="$l10n_wc_costmode_short" width="160px"/>
                        <MultiTextOption profile="WC_FilterSwitcher" id="optCostMode" size="365px 32px"/>
                    </BoxLayout>

                    <!-- WAGE LEVEL -->
                    <Text profile="WC_SectionTitle" position="10px -284px" text="$l10n_wc_section_wage_level"/>
                    <ThreePartBitmap profile="fs25_lineSeparatorTop" position="5px -308px" width="540px"/>

                    <BoxLayout profile="WC_RowBoxH" position="5px -328px" width="540px">
                        <Text profile="WC_RowLabel" text="$l10n_wc_difficulty_short" width="160px"/>
                        <MultiTextOption profile="WC_FilterSwitcher" id="optWageLevel" size="365px 32px"/>
                    </BoxLayout>

                    <!-- Reset button -->
                    <Button profile="fs25_buttonOK" id="btnReset" onClick="onClickReset"
                            text="$l10n_wc_reset" position="10px -430px" width="240px"/>

                </GuiElement>
            </ThreePartBitmap>

            <!-- Vertical separator -->
            <Bitmap profile="fs25_settingsTooltipSeparator" position="620px 0px"/>

            <!-- RIGHT: Live rate preview + Help -->
            <GuiElement position="640px 0px" width="460px" height="580px">

                <!-- EFFECTIVE RATE (big display) -->
                <Text profile="WC_SectionTitle" position="0px -10px" text="$l10n_wc_section_effective"/>
                <ThreePartBitmap profile="fs25_lineSeparatorTop" position="0px -34px" width="440px"/>

                <Text profile="WC_BigStatLabel" position="0px -58px" text="$l10n_wc_label_effective_rate"/>
                <Text profile="WC_BigStat" id="txtBigRate" position="0px -78px"/>
                <Text profile="WC_BigStatLabel" id="txtRateLabel" position="0px -126px"/>

                <ThreePartBitmap profile="fs25_lineSeparatorTop" position="0px -154px" width="440px"/>

                <BoxLayout profile="WC_RowBoxH" position="0px -174px" width="440px">
                    <Text profile="WC_RowLabel" text="$l10n_wc_label_pay_interval" width="220px"/>
                    <Text profile="WC_RowValue" id="txtPayInterval" width="210px"/>
                </BoxLayout>

                <!-- HELP -->
                <Text profile="WC_SectionTitle" position="0px -230px" text="$l10n_wc_help_title"/>
                <ThreePartBitmap profile="fs25_lineSeparatorTop" position="0px -254px" width="440px"/>
                <Text profile="WC_BodyText" position="0px -274px" width="440px" text="$l10n_wc_help_body"/>

            </GuiElement>

        </GuiElement>

    </GuiElement>
</GUI>
